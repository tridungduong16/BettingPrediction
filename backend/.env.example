APP_ENV=local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

WORLDCUP_DEFAULT_YEAR=2026
WORLDCUP_CACHE_TTL_SECONDS=900
WORLDCUP_DATA_DIR=./data
WORLDCUP_HTTP_TIMEOUT_SECONDS=20

# Optional overrides. Use {year} in URL templates.
WORLDCUP_UPBOUND_JSON_URL=https://raw.githubusercontent.com/upbound-web/worldcup-live.json/master/{year}/worldcup.json
WORLDCUP_OPENFOOTBALL_JSON_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/{year}/worldcup.json
WORLDCUP_SOURCE_TEXT_URL=https://raw.githubusercontent.com/openfootball/worldcup/master/{year}--usa/cup.txt

# Live match events. API key can be added later; routes return provider_status=not_configured
# until this is set.
API_FOOTBALL_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
LIVE_EVENTS_CACHE_TTL_SECONDS=5
LIVE_EVENTS_HTTP_TIMEOUT_SECONDS=10
LIVE_EVENTS_FIXTURE_MAP_FILE=./data/live_fixture_map.json

# Prediction/analytics cache. When Redis is reachable, repeated analytic clicks reuse cached
# LLM output instead of calling the model again.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT_SECONDS=1
PREDICTION_CACHE_TTL_SECONDS=21600
PREDICTION_CACHE_KEY_PREFIX=futbolia
PREDICTION_CACHE_VERSION=v1

# Agent / LLM settings. Leave empty until prediction/chat agents are wired to a model gateway.
BIFROST_ENDPOINT_URL=https://bifrost.azaps.net/v1
BIFROST_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=openainexira/gpt-5.4-mini
MODEL_NAME=openainexira/gpt-5.4-mini
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
DASHSCOPE_EMBEDDING_BASE_URL=
